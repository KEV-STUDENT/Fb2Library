{
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api-destination": {
            "Address": "https://localhost:7029/" // HTTPS!
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true // Для разработки
        }
      }
    }
  }
}
